# =============================================================================
# ProductJarvis Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# --- LLM Providers ---
# Server-side LLM traffic is configured for Supabase Edge Functions.
# Set these only if you are providing a custom gateway or direct provider keys.
AI_GATEWAY_BASE_URL=
AI_GATEWAY_KEY=
# Optional direct Anthropic fallback
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --- LLM Model overrides (optional — per-prompt routing uses these by default) ---
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6-20250929
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6-thinking
# CLAUDE_MODEL=   # Set this to override all per-prompt routing with a single model
CLAUDE_TIMEOUT_MS=60000
OPENAI_MODEL=gpt-5.1
OPENAI_TIMEOUT_MS=60000

# --- Frontend (Vite) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_BASE_URL=https://api.productjarvis.com
VITE_AI_GATEWAY_BASE=
VITE_AI_GATEWAY_KEY=
VITE_SENTRY_DSN=https://xxx@sentry.io/xxx
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://app.posthog.com

# --- CORS (comma-separated origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://productjarvis.com,https://www.productjarvis.com,https://app.productjarvis.com

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Integration OAuth (Jira, Linear, Notion) ---
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=https://auth.productjarvis.com/integrations/callback

LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=https://auth.productjarvis.com/integrations/callback

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=https://auth.productjarvis.com/integrations/callback

# Token encryption key (32+ characters, keep secret)
TOKEN_ENCRYPTION_KEY=your-secret-encryption-key-min-32-chars
