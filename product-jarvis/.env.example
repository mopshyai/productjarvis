# =============================================================================
# ProductJarvis Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# --- LLM Providers ---
# Option A: Quatarly unified gateway (recommended — proxies Claude, GPT, Gemini via one key)
ANTHROPIC_BASE_URL=https://api.quatarly.cloud/
ANTHROPIC_AUTH_TOKEN=qua_your-quatarly-key
OPENAI_BASE_URL=https://api.quatarly.cloud/v1
OPENAI_API_KEY=qua_your-quatarly-key
# Option B: Direct Anthropic (kept as fallback; ANTHROPIC_AUTH_TOKEN takes priority when set)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --- LLM Model overrides (optional — per-prompt routing uses these by default) ---
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6-20250929
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6-thinking
# CLAUDE_MODEL=   # Set this to override all per-prompt routing with a single model
CLAUDE_TIMEOUT_MS=60000
OPENAI_MODEL=gpt-5.1
OPENAI_TIMEOUT_MS=60000

# --- Frontend (Vite) ---
VITE_USE_LIVE_API=true
VITE_API_BASE_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1

# --- CORS (comma-separated origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://productjarvis.com,https://www.productjarvis.com,https://app.productjarvis.com

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
